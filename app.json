{
  "expo": {
    "name": "parent-plus",
    "slug": "parent-plus",
    "scheme": "parentplus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#F8F0F6"
      },
      "package": "com.romeenice.parentplus"
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-localization",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "62991aee-1eb7-4e5f-900b-36c160f7fe9b"
      }
    }
  }
}
